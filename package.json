{
  "name": "compressor-de-video",
  "version": "1.0.0",
  "description": "Compressor de vídeo desktop premium utilizando Electron e FFmpeg",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.0",
    "fluent-ffmpeg": "^2.1.2"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.videosqueeze.app",
    "productName": "VideoSqueeze",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoSqueeze"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/jest/**/*",
      "!node_modules/@jest/**/*",
      "!node_modules/jest-*/**/*",
      "!tests/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*"
    ]
  }
}

